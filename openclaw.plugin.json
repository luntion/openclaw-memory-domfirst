{
  "kind": "context-engine",
  "id": "openclaw-memory-domfirst",
  "name": "OpenClaw Memory DomFirst",
  "version": "0.3.0",
  "description": "Scoped elastic memory engine with layered recall and local service",
  "configSchema": {
    "type": "object",
    "properties": {
      "dbPath": {
        "type": "string",
        "default": "~/.openclaw/openclaw-memory-domfirst.db",
        "description": "SQLite database path"
      },
      "serviceHost": {
        "type": "string",
        "default": "127.0.0.1",
        "description": "Local memory service host"
      },
      "servicePort": {
        "type": "integer",
        "default": 42690,
        "description": "Local memory service port"
      },
      "teamId": {
        "type": "string",
        "default": "team-default",
        "description": "Default team scope identifier"
      },
      "defaultAgentId": {
        "type": "string",
        "default": "agent-main",
        "description": "Fallback agent scope identifier"
      },
      "defaultProjectId": {
        "type": "string",
        "description": "Fallback project scope identifier"
      },
      "knowledgeMarkers": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Text markers used to include explicit knowledge files"
      },
      "compactTurnCount": {
        "type": "integer",
        "default": 6,
        "description": "Maintenance interval in turns"
      },
      "recallMaxNodes": {
        "type": "integer",
        "default": 6,
        "description": "Default max recall nodes"
      },
      "recallMaxDepth": {
        "type": "integer",
        "default": 2,
        "description": "Default graph walk depth"
      },
      "embedding": {
        "type": "object",
        "properties": {
          "apiKey": { "type": "string" },
          "baseURL": { "type": "string" },
          "model": { "type": "string" },
          "dimensions": { "type": "integer" }
        }
      },
      "llm": {
        "type": "object",
        "properties": {
          "apiKey": { "type": "string" },
          "baseURL": { "type": "string" },
          "model": { "type": "string" }
        }
      },
      "backend": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "default": "sqlite",
            "description": "Storage backend mode: sqlite or graphiti-neo4j"
          },
          "graphiti": {
            "type": "object",
            "properties": {
              "baseUrl": {
                "type": "string",
                "default": "http://127.0.0.1:8000",
                "description": "Graphiti service base URL"
              },
              "groupPrefix": {
                "type": "string",
                "default": "ocm",
                "description": "Graphiti group prefix used for scope namespaces"
              },
              "timeoutMs": {
                "type": "integer",
                "default": 20000,
                "description": "Graphiti request timeout in milliseconds"
              }
            }
          },
          "neo4j": {
            "type": "object",
            "properties": {
              "uri": {
                "type": "string",
                "default": "bolt://127.0.0.1:7687",
                "description": "Neo4j Bolt URI"
              },
              "username": {
                "type": "string",
                "default": "neo4j",
                "description": "Neo4j username"
              },
              "password": {
                "type": "string",
                "default": "password",
                "description": "Neo4j password"
              },
              "database": {
                "type": "string",
                "default": "neo4j",
                "description": "Neo4j database name"
              },
              "workspace": {
                "type": "string",
                "default": "main",
                "description": "Logical workspace namespace used by DomFirst memory nodes"
              }
            }
          }
        }
      }
    }
  }
}
